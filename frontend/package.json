{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:snapshots": "vitest --run tests/uiStandards.snapshot.test.js",
    "test:visual-optional": "node scripts/assert-visual-regression-clean.mjs",
    "verify": "npm run lint && npm run test -- --run && npm run build",
    "e2e": "node scripts/run-e2e.mjs",
    "e2e:run": "cypress run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "audit:breakpoints": "bash ../audit-breakpoints.sh",
    "repo:hygiene": "python ../scripts/repo_hygiene_check.py"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "axios": "^1.13.4",
    "chart.js": "^4.4.0",
    "chartjs-chart-matrix": "^3.0.0",
    "mermaid": "^11.12.3",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph": "^1.29.3",
    "react-force-graph-2d": "^1.29.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "cypress": "^15.11.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^8.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
