# Copy to /etc/fantasy-football-pi/backend.env and adjust values.
DATABASE_URL=postgresql://postgres:football-pi@127.0.0.1:5432/fantasy_football
ALLOW_ALL_ORIGINS=0
FRONTEND_ALLOWED_ORIGINS=https://YOUR_DOMAIN
ALLOWED_HOSTS=YOUR_DOMAIN,localhost,127.0.0.1
ACCESS_TOKEN_COOKIE_NAME=ffpi_access_token
CSRF_COOKIE_NAME=ffpi_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
# Gemini / Google AI API key for the League Chatbot advisor.
# Either GEMINI_API_KEY or GOOGLE_API_KEY is accepted.
# Without this the chatbot will show an "offline" message.
GEMINI_API_KEY=
GOOGLE_API_KEY=
# AUTO_SEED_ON_STARTUP: set to "1" to seed baseline data on every backend start (dev only).
AUTO_SEED_ON_STARTUP=0
