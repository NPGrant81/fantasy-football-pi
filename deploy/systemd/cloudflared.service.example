[Unit]
Description=Cloudflare Tunnel for Fantasy Football Pi
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=cloudflared
Group=cloudflared
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env cloudflared --config /etc/cloudflared/config.yml tunnel run
Restart=on-failure
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=20

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/cloudflared /etc/cloudflared

[Install]
WantedBy=multi-user.target
