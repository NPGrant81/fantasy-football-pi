# Local backend runtime settings (copy to backend/.env and adjust as needed)
DATABASE_URL=postgresql://postgres:football-pi@127.0.0.1:5432/fantasy_football

# Yahoo Fantasy Sports OAuth2
# Get client ID and secret from https://developer.yahoo.com/apps/ (create a
# "Fantasy Sports" app with read scope).  Access/refresh tokens are generated
# the first time you authorize the app via the OAuth2 flow.
# These are read by etl/extract/extract_yahoo.py before falling back to
# the legacy oauth2.json file at the project root.
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_ACCESS_TOKEN=
YAHOO_REFRESH_TOKEN=
